### Server-only (never exposed to the browser — read by /api/chat)
AZURE_OPENAI_ENDPOINT="https://your-resource.cognitiveservices.azure.com/"
AZURE_OPENAI_KEY="your-azure-openai-key-here"
AZURE_OPENAI_DEPLOYMENT="your-deployment-name"
AZURE_OPENAI_MODEL="gpt-5.3-chat"
AZURE_OPENAI_VERSION="2024-12-01-preview"

### Image generation (GPT-image-2 via Azure) — read by /api/image-gen
# Separate deployment from the chat one; share the same endpoint + key.
AZURE_OPENAI_IMAGE_DEPLOYMENT="your-gpt-image-2-deployment"
AZURE_OPENAI_IMAGE_VERSION="2025-04-01-preview"

### Stripe (Phase 3 — not yet wired into the client)
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRICE_PRO_MONTHLY="price_..."

### Resend (Phase 3 — transactional email)
# RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="hello@layaa.ai"

### Server-side Supabase access (used by edge functions for cost logs etc.)
# SUPABASE_URL="https://your-project-ref.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="service_role_key_here"

### Client (must be VITE_-prefixed to reach the browser)
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Preferred: new-style publishable key (sb_publishable_...)
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_your_key_here"

# Legacy fallback: classic anon JWT (still accepted; either var works)
# VITE_SUPABASE_ANON_KEY="eyJhbGci..."
